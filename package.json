{
  "name": "agent-orch",
  "version": "1.0.0",
  "description": "Lightweight self-orchestrating multi-agent CLI for DeepSeek + GLM + MiMo",
  "type": "module",
  "main": "dist/cli/main.js",
  "bin": {
    "agent-orch": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:types": "tsc --emitDeclarationOnly",
    "build:all": "npm run build && npm run build:types",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:all"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "minimatch": "^10.0.3",
    "winston": "^3.17.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "cheerio": "^1.2.0"
  },
  "peerDependencies": {
    "ink": "^5.0.0",
    "react": "^18.3.0"
  },
  "peerDependenciesMeta": {
    "ink": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "esbuild": "^0.27.0",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "multi-agent",
    "cli",
    "orchestrator",
    "deepseek",
    "glm",
    "mimo",
    "llm",
    "ai-agent"
  ]
}
